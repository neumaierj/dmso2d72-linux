# Joy-IT DMSO2D72 / Hantek 2D72 handheld oscilloscope — allow non-root USB access.
# Install with:
#   sudo cp udev/99-dmso2d72.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="2d42", TAG+="uaccess", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="2d72", TAG+="uaccess", MODE="0666"
